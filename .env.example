# Plain HTTP port. Requests redirect to HTTPS when REDIRECT_TO_HTTPS=true.
# 普通 HTTP 端口；REDIRECT_TO_HTTPS=true 时会自动跳转到 HTTPS。
HTTP_PORT=19000

# HTTPS port used by the Express and Socket.IO server.
# Express 和 Socket.IO 使用的 HTTPS 端口。
HTTPS_PORT=19001

# Redirect all HTTP requests to HTTPS; keep true for browser camera and screen APIs.
# 是否强制 HTTP 跳转 HTTPS；浏览器摄像头和屏幕共享通常需要保持 true。
REDIRECT_TO_HTTPS=true

# Trust X-Forwarded-* headers from a reverse proxy.
# 是否信任反向代理传入的 X-Forwarded-* 请求头。
TRUST_PROXY=true

# Path to the TLS private key used by Docker Compose.
# Docker Compose 使用的 TLS 私钥文件路径；本地 npm start 默认使用 server/certs/key.pem。
SSL_KEY_PATH=/app/server/certs/key.pem

# Path to the TLS certificate used by Docker Compose.
# Docker Compose 使用的 TLS 证书文件路径；本地 npm start 默认使用 server/certs/cert.pem。
SSL_CERT_PATH=/app/server/certs/cert.pem

# Express session signing secret; change this before public deployment.
# Express Session 签名密钥，公开部署前必须修改。
SESSION_SECRET=change-this-session-secret

# Mark session cookies as HTTPS-only.
# 是否给 Session Cookie 添加 HTTPS-only 限制。
SESSION_COOKIE_SECURE=true

# Session lifetime in milliseconds; default is 8 hours.
# Session 有效期，单位毫秒；默认 8 小时。
SESSION_MAX_AGE_MS=28800000

# MySQL host; in Docker Compose this must match the mysql service name.
# MySQL 主机；Docker Compose 中必须和 mysql 服务名一致。
DB_HOST=mysql

# MySQL port inside the Docker network or on the external database host.
# MySQL 端口，指 Docker 网络内端口或外部数据库端口。
DB_PORT=3306

# Application database user; Compose creates this user on first database initialization.
# 应用连接数据库使用的用户名；Compose 首次初始化数据库时会创建该用户。
DB_USER=proctoring

# Application database password; change this before public deployment.
# 应用连接数据库使用的密码，公开部署前必须修改。
DB_PASSWORD=change-this-db-password

# MySQL database/schema name.
# MySQL 数据库/Schema 名称。
DB_NAME=proctoring_system

# Maximum MySQL connections kept in the Node.js pool.
# Node.js MySQL 连接池最大连接数。
DB_CONNECTION_LIMIT=10

# Enable original dual-IP behavior for internal and external clients.
# 是否启用原来的内外网双 IP 判断逻辑。
MEDIASOUP_COMPLEX_NETWORK_MODE=false

# Browser-reachable IP or DNS name for WebRTC UDP.
# 浏览器可访问的 WebRTC UDP 地址，局域网 Docker 测试时通常填宿主机局域网 IP。
MEDIASOUP_ANNOUNCED_IP=127.0.0.1

# IP address mediasoup binds to; use 0.0.0.0 in Docker.
# mediasoup 监听绑定的 IP；Docker 中建议使用 0.0.0.0。
MEDIASOUP_INTERNAL_IP=0.0.0.0

# Internal client IP prefix used only when MEDIASOUP_COMPLEX_NETWORK_MODE=true.
# 内网客户端 IP 前缀，仅在 MEDIASOUP_COMPLEX_NETWORK_MODE=true 时使用。
MEDIASOUP_INTERNAL_SUBNET=192.168.100.

# First UDP port used by mediasoup workers.
# mediasoup worker 使用的起始 UDP 端口。
MEDIASOUP_BASE_PORT=40000

# Number of UDP ports reserved per mediasoup worker.
# 每个 mediasoup worker 预留的 UDP 端口数量。
MEDIASOUP_PORTS_PER_WORKER=1000

# Maximum mediasoup workers; Compose defaults to 1 for first-run simplicity.
# mediasoup worker 最大数量；Compose 默认 1 个，便于首次启动少踩端口映射问题。
MEDIASOUP_MAX_WORKERS=1

# CPU cores left unused when calculating worker count.
# 自动计算 worker 数量时预留不用的 CPU 核心数。
MEDIASOUP_RESERVED_CPU_CORES=2

# Last UDP port published by Docker Compose.
# Docker Compose 对外发布的最后一个 UDP 端口。
MEDIASOUP_PUBLISHED_MAX_PORT=40999

# Recording storage directory; in Compose this path is backed by a volume.
# 录像存储目录；Compose 中该路径由 volume 持久化。
RECORDINGS_DIR=/app/public/recordings
